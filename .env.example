# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Postgres password for the broker DB
POSTGRES_PASSWORD=changeme_strong_password

# Fernet key for encrypting api_keys.token at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_SECRET=

# Master admin key — bootstrap. After first project is created, store in vault.
# Generate: python -c "import secrets; print('aib_admin_' + secrets.token_urlsafe(32))"
ADMIN_KEY=

# Internal HMAC for monitor↔api auth
INTERNAL_SECRET=

# ─── ALERTS + DASHBOARD LOGIN ──────────────────────────────────────────────
# Reuse Vera's bot (Dimondra_Ai_Bot) — broker pings owner on incidents AND
# is used for Telegram Login Widget on /dashboard
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=Dimondra_Ai_Bot
OWNER_TELEGRAM_ID=169510539

# HMAC session cookie secret for /dashboard browser sessions.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# ─── LIMITS ─────────────────────────────────────────────────────────────────
# Global daily cap across all projects (USD); per-project caps live in DB
GLOBAL_DAILY_CAP_USD=20.0

# Default lease duration for vending mode (seconds)
DEFAULT_LEASE_SECONDS=60

# ─── DEPLOY/HOST ────────────────────────────────────────────────────────────
PUBLIC_HOST=aib.zapleo.com
LOG_LEVEL=INFO
